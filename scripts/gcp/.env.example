# =============================================================================
# Skills Hub — GCP 部署環境變數範本（S013）
# =============================================================================
# 使用方式：
#   1. cp scripts/gcp/.env.example scripts/gcp/.env
#   2. 編輯 .env 填上 3 個必填值
#   3. source scripts/gcp/.env
#   4. 依序跑 01-bootstrap.sh → 02-create-secrets.sh → 03-build-push.sh → 04-deploy.sh
#
# .env 已被 scripts/gcp/.gitignore 排除，不會誤 commit 真實 secret。
# =============================================================================

# ── 必填 ─────────────────────────────────────────────────────
# GCP 專案 ID（請先 `gcloud projects create my-skillshub-prod` 並啟用 billing account）
export GCP_PROJECT_ID=my-skillshub-prod

# 部署 region（建議 asia-east1 / us-central1；需與 Firestore Enterprise 支援的 region 一致）
export GCP_REGION=asia-east1

# Vertex AI Gemini API key — 取得：https://aistudio.google.com/app/apikey
# 此值會存到 Secret Manager（02-create-secrets.sh），不會直接放進 Cloud Run env var
export SKILLSHUB_GENAI_API_KEY=AIzaSy...

# ── 可選（皆有預設）─────────────────────────────────────────
# Artifact Registry Docker repo 名稱
export AR_REPO_NAME=skillshub

# Firestore database ID（lowercase letters/numbers/hyphens, 4-63 字元）
export FIRESTORE_DB_ID=skillshub

# GCS bucket 名稱（必須全球唯一；預設用 ${GCP_PROJECT_ID} 前綴避免撞名）
export GCS_BUCKET_NAME=${GCP_PROJECT_ID}-skillshub-pkg

# Runtime Service Account 名稱（不含 @project.iam.gserviceaccount.com 後綴）
export SERVICE_ACCOUNT_NAME=skillshub-runtime

# Cloud Run service 名稱
export CLOUD_RUN_SERVICE_NAME=skillshub

# Image 名稱（在 Artifact Registry 內的 image 部分）
export IMAGE_NAME=skillshub

# Cloud Run 資源配額（依用量調整）
export CLOUD_RUN_MEMORY=512Mi
export CLOUD_RUN_CPU=1
export CLOUD_RUN_MAX_INSTANCES=10
