# =============================================================================
# Skills Hub — GCP 部署環境變數範本
# =============================================================================
# 使用方式：
#   1. cp scripts/gcp/.env.example scripts/gcp/.env
#   2. 編輯 .env 填上必填值
#   3. source scripts/gcp/.env
#   4. 依序跑 01-bootstrap.sh → 02-create-secrets.sh → 03-build-push.sh → 04-deploy.sh
#
# 架構：Cloud Run multi-container = Spring Boot + cloud-sql-proxy sidecar；
#       資料庫 Cloud SQL PostgreSQL 18 + pgvector，DB 認證走帳密（Secret Manager）。
#
# .env 已被 scripts/gcp/.gitignore 排除，不會誤 commit 真實 secret。
# =============================================================================

# ── 必填 ─────────────────────────────────────────────────────
# GCP 專案（請先 `gcloud projects create my-skillshub-prod` 並啟用 billing）
export GCP_PROJECT_ID=my-skillshub-prod

# 部署 region（建議 asia-east1 / us-central1）
export GCP_REGION=asia-east1

# 應用程式專用 DB 密碼（建議 24+ 字元；02 step 會存進 Secret Manager 後即可清空）
export DB_PASSWORD='change-me-to-a-strong-password'

# Google AI Studio Gemini API key（**非** Vertex AI；走 generativelanguage.googleapis.com 端點 + API key auth）
# 取得：https://aistudio.google.com/apikey
export SKILLSHUB_GENAI_API_KEY='AIzaSy...'

# ── 可選（皆有合理預設）─────────────────────────────────────
# Artifact Registry Docker repo 名稱
export AR_REPO_NAME=skillshub
export IMAGE_NAME=skillshub

# Cloud Run service / runtime SA / GCS bucket
export CLOUD_RUN_SERVICE_NAME=skillshub
export SERVICE_ACCOUNT_NAME=skillshub-runtime
export GCS_BUCKET_NAME=${GCP_PROJECT_ID}-skillshub-pkg

# Cloud SQL（PostgreSQL 18 自 2025-11-20 GA；--edition=ENTERPRISE 才能用 db-f1-micro 起步）
export CLOUDSQL_INSTANCE_NAME=skillshub-db
export CLOUDSQL_EDITION=ENTERPRISE
export CLOUDSQL_TIER=db-f1-micro
export DB_NAME=skillshub
export DB_USER=skillshub_app

# Spring profile 組合（順序：behavior,infra — 行為先、infra 後覆蓋）
#   lab,gcp  — 封測 / MVP（OAuth off、完整 actuator、Springdoc、DEBUG app log）
#   prod,gcp — 正式（OAuth on、限縮 actuator、INFO log）
# 注：行為 profile 先載讓基礎設定就位，再讓 infra (gcp) profile 補 GCP 專屬設定
export SPRING_PROFILES_ACTIVE=lab,gcp

# Cloud Run 資源（Spring Boot 主 app；sidecar 額外 1 CPU / 256Mi → 整 instance 共 2 CPU / 1280Mi）
export CLOUD_RUN_CPU=1
export CLOUD_RUN_MEMORY=1Gi
export CLOUD_RUN_MAX_INSTANCES=10

# ── 衍生（不要改；放在最後因依賴上面變數先 set）─────────────────
export SA_EMAIL=${SERVICE_ACCOUNT_NAME}@${GCP_PROJECT_ID}.iam.gserviceaccount.com
export CLOUDSQL_INSTANCE_CONN=${GCP_PROJECT_ID}:${GCP_REGION}:${CLOUDSQL_INSTANCE_NAME}
export IMG_BASE=${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${AR_REPO_NAME}/${IMAGE_NAME}
