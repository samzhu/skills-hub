# =============================================================================
# 本地開發機敏設定範例（此檔案提交 Git，請勿填入實際機敏值）
# =============================================================================
# 使用方式：
#   1. cp config/application-secrets.properties.example config/application-secrets.properties
#   2. 編輯 .properties（無 .example）填入實際值
#   3. 啟動應用程式：./gradlew bootRun
#
# 命名規則：dot.lower.case（與 @ConfigurationProperties 屬性路徑 1:1）
#   skillshub.xxx.yyy=value
#
# -----------------------------------------------------------------------------
# 統一機敏值管理機制 — 同一 property 名跨環境，只是注入來源不同
# -----------------------------------------------------------------------------
# 屬性如 skillshub.db.password / skillshub.genai.api-key 跨 local / lab / prod
# 都用相同 property 名；Spring 不在意值從哪來，僅靠 PropertyResolver 統一拿值：
#
#   ┌─ 本機 dev ─────────────────────────────────────────────────────────┐
#   │ application-secrets.properties 直接填明文值（此檔，已 .gitignore） │
#   │   skillshub.db.password=secret                                       │
#   │   skillshub.genai.api-key=AIzaSy...                                  │
#   └──────────────────────────────────────────────────────────────────────┘
#
#   ┌─ Cloud Run（lab / prod）──────────────────────────────────────────────────┐
#   │ service.yaml env var 注入 sm@ URI 字串：                                  │
#   │   - name: skillshub.db.password                                           │
#   │     value: ${sm@skillshub-db-password}      ← 字面字串                    │
#   │ Spring 啟動時 PropertyResolver 遞迴 resolve：                             │
#   │   ${skillshub.db.password} → "${sm@skillshub-db-password}" → SM 實際值    │
#   │ （spring-cloud-gcp-starter-secretmanager 的 SecretManagerPropertySource   │
#   │   攔下 sm@ 前綴，從 Secret Manager 拉對應 secret 最新版本）               │
#   │                                                                           │
#   │ envsubst 渲染 service.yaml 時走 whitelist 模式（04-deploy.sh），           │
#   │ 不替換 ${sm@xxx} — 字串保留交給 Spring runtime 處理                       │
#   └───────────────────────────────────────────────────────────────────────────┘
#
# 好處：
#   - 同一 property 名，本機改 .properties，雲端改 Secret Manager — 切換無感
#   - 應用碼跨環境一致（@ConfigurationProperties / @Value 取值不變）
#   - secret.yaml 不寫死 sm@：注入機制由部署層（service.yaml）決定
#
# -----------------------------------------------------------------------------
# 非機敏值（如 skillshub.storage.bucket）— 走 Cloud Run env var 直接注入
# -----------------------------------------------------------------------------
# K8s RelaxedEnvironmentVariableValidation（2025-06-28 GA）允許 env name 含 dot，
# Cloud Run env name 直接對齊 Spring property（service.yaml 內 - name: skillshub.storage.bucket）
#
# -----------------------------------------------------------------------------
# 注意：application-secrets.properties（無 .example）已加入 .gitignore，
#       請勿將含有實際機敏值的檔案提交到版本控制系統。
# =============================================================================


# =============================================================================
# Database password — 本機 Docker Compose 預設密碼
# =============================================================================
# 對齊 backend/compose.yaml 的 POSTGRES_PASSWORD（compose 啟動 pgvector 用）
# 不需要改；除非你本機 DB 用了不同密碼

skillshub.db.password=secret


# =============================================================================
# Google GenAI Embedding API key（語意搜尋）
# =============================================================================
# 取得：https://aistudio.google.com/apikey （Google AI Studio，**非** Vertex AI）
# 設定後 GET /api/v1/search/semantic?q=... 可回傳真實向量相關結果；
# 未設定時 LlmJudge bean 不建立（@ConditionalOnProperty 把關），
# 語意搜尋走 NoOpEmbeddingModel（零向量），其餘功能正常。

# skillshub.genai.api-key=AIzaSy...
