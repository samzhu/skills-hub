# =============================================================================
# 本地開發機敏設定範例（此檔案提交 Git）
# =============================================================================
# 使用方式：
#   1. 複製此檔案：cp config/application-secrets.properties.example config/application-secrets.properties
#   2. 編輯填入實際值
#   3. 啟動應用程式：./gradlew bootRun
#
# 注意：application-secrets.properties（無 .example）已加入 .gitignore，
#       請勿將含有實際機敏值的檔案提交到版本控制系統。
# =============================================================================

# MongoDB 連線 URI（本地 Docker Compose 預設值已足夠，通常不需修改）
skillshub-mongodb-uri=mongodb://localhost:27017/skillshub

# GCS Bucket 名稱（本地使用 InMemoryStorageService，此值僅供 GCP profile 使用）
skillshub-storage-bucket=skillshub-packages
